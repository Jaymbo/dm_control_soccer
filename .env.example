# ============================================================
# MASTER SERVER CONFIGURATION (24/7)
# Copy to .env on master server
# ============================================================

# PostgreSQL Database (Optuna Storage)
POSTGRES_USER=optuna
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=optuna_db
POSTGRES_PORT=5432

# MLflow Server
MLFLOW_PORT=5000

# Optuna Dashboard
DASHBOARD_PORT=8080


# ============================================================
# WORKER CONFIGURATION (Slave Devices)
# Copy to .env on worker devices
# ============================================================

# Connection to Master Server
# For Cloudflare Zero Trust: use hostname:443
# For SSH Tunnel: use localhost:5432
# For VPN: use private IP
OPTUNA_STORAGE=postgresql://optuna:CHANGE_ME_TO_SECURE_PASSWORD@MASTER_IP:5432/optuna_db

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://MASTER_IP:5000

# Study Configuration
OPTUNA_STUDY_NAME=soccer_dynamic_v1
OPTUNA_N_TRIALS=10
OPTUNA_TIMEOUT=0

# Worker Identification (optional)
OPTUNA_WORKER_ID=worker-01

# Enable Dynamic Scoring Rewards
OPTUNA_USE_DYNAMIC_REWARDS=true

# Logging
OPTUNA_LOG_TO_FILE=false
OPTUNA_LOG_DIR=logs/optuna

# Hardware Configuration (auto-detected if not set)
# PYTORCH_DEVICE=cuda  # Options: cuda, cpu, mps
# MUJOCO_GL=egl  # Options: egl, osmesa, glfw

# Resource Limits (Docker Compose)
# CPU_LIMIT=4
# CPU_RESERVATION=1


# ============================================================
# LOCAL TESTING (SQLite, no network required)
# ============================================================

# For local testing without master server:
# OPTUNA_STORAGE=sqlite:///optuna.db
# MLFLOW_TRACKING_URI=  # Leave empty to disable MLflow
