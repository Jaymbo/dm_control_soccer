# ============================================
# MLflow + Optuna Master Configuration
# ============================================
# Copy this file to .env and adjust for your setup
# Used by: docker-compose.master.yml

# PostgreSQL Configuration
POSTGRES_USER=optuna
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=optuna_db
POSTGRES_PORT=5432

# MLflow Server
MLFLOW_PORT=5000

# Optuna Dashboard
DASHBOARD_PORT=8080


# ============================================
# Worker Configuration
# ============================================
# Used by: docker-compose.worker.yml, worker_entrypoint.py

# Connection to Master Server (REQUIRED)
# Replace MASTER_IP with your server's IP or domain
OPTUNA_STORAGE=postgresql://optuna:CHANGE_ME_TO_SECURE_PASSWORD@MASTER_IP:5432/optuna_db
MLFLOW_TRACKING_URI=http://MASTER_IP:5000

# Study Configuration
OPTUNA_STUDY_NAME=soccer_dynamic_v1

# Number of trials per worker run (use large number or --infinite flag)
OPTUNA_N_TRIALS=10

# Timeout in seconds (0 = no timeout)
OPTUNA_TIMEOUT=0

# Enable Dynamic Scoring rewards (recommended)
OPTUNA_USE_DYNAMIC_REWARDS=true

# Optional: Worker ID for logging (auto-generated if not set)
# OPTUNA_WORKER_ID=laptop-01

# Enable file logging for workers
OPTUNA_LOG_TO_FILE=false

# Log directory for Optuna
OPTUNA_LOG_DIR=logs/optuna


# ============================================
# MuJoCo Renderer Configuration
# ============================================
# REQUIRED to avoid memory errors with GLIBC 2.43+
# Set these before running any training script

# EGL rendering (works on headless servers)
MUJOCO_GL=egl
PYOPENGL_PLATFORM=egl

# Alternative: OSMesa (software rendering, slower but more compatible)
# MUJOCO_GL=osmesa
# PYOPENGL_PLATFORM=osmesa

# Alternative: GLFW (requires display)
# MUJOCO_GL=glfw


# ============================================
# PyTorch Device Configuration
# ============================================
# Auto-detected if not set

# Force CPU
# PYTORCH_DEVICE=cpu

# Force CUDA (NVIDIA GPU)
# PYTORCH_DEVICE=cuda

# Force MPS (Apple Silicon)
# PYTORCH_DEVICE=mps


# ============================================
# Docker Worker Optional Configuration
# ============================================
# Uncomment and adjust in docker-compose.worker.yml

# CPU limits
# CPU_LIMIT=4
# CPU_RESERVATION=1

# GPU support (NVIDIA)
# Uncomment deploy section in docker-compose.worker.yml

# MuJoCo renderer in Docker (inherits from environment)
# MUJOCO_GL=egl
# PYOPENGL_PLATFORM=egl
